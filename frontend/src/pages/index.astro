---
// The Wire — styled to match hadimoumeni.com (monochrome, JetBrains Mono, grain).
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>The Wire — earnings-call intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Sora:wght@500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="grain"></div>

  <div class="wrap">
    <header class="masthead animate-in">
      <div class="brand">
        <span class="site-name">THE&nbsp;WIRE</span>
        <span class="currently"><span class="label">model /</span> <span class="now" id="modelBadge">checking…</span></span>
      </div>
      <div class="tagline">earnings calls → verified investment theses</div>
    </header>

    <main class="container">
      <section class="panel animate-in animate-delay-1">
        <div class="field-row">
          <label>ticker<input id="ticker" value="NWL" autocomplete="off" /></label>
          <label>quarter<input id="quarter" value="Q3 2026" autocomplete="off" /></label>
        </div>
        <textarea id="transcript" placeholder="paste an earnings-call transcript…"></textarea>
        <div class="actions">
          <button id="loadSample" class="btn ghost">load sample</button>
          <button id="analyze" class="btn">analyze →</button>
        </div>
      </section>

      <section id="empty" class="empty animate-in animate-delay-2">
        <p>three specialist agents — sentiment · risk · guidance — read the call
        in parallel. a verifier checks every quote against the transcript before
        the thesis ships. any format works.</p>
      </section>

      <section id="memo" class="memo hidden"></section>

      <section class="recent-wrap">
        <h2 class="section-label">recent</h2>
        <ul id="recent" class="recent"></ul>
      </section>
    </main>

    <footer class="bottom-bar">
      <span class="location">the wire</span>
      <span class="dot">·</span>
      <span class="social-links">
        <a href="https://github.com/hadimoumeni/the_wire" target="_blank" rel="noopener">github</a>
      </span>
    </footer>
  </div>

  <script>
    const API = location.port === '4321' ? 'http://localhost:2424' : '';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s ?? '').toString()
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const stanceGlyph = { bullish: '▲', bearish: '▼', neutral: '—' };
    const dirGlyph = { raised: '↑', lowered: '↓', maintained: '→', introduced: '+',
                       withdrawn: '×', unclear: '?' };

    async function health() {
      const b = $('modelBadge');
      try {
        const h = await (await fetch(API + '/api/health')).json();
        b.textContent = h.model_available ? h.model : 'heuristic (no model)';
      } catch { b.textContent = 'api offline'; }
    }

    async function loadRecent() {
      try {
        const rows = await (await fetch(API + '/api/theses')).json();
        $('recent').innerHTML = rows.map(r => `
          <li data-id="${r.id}">
            <span class="r-glyph">${stanceGlyph[r.stance] || '—'}</span>
            <span class="r-tk">${esc(r.ticker)} <span class="dim">${esc(r.quarter)}</span></span>
            <span class="r-conv">${r.conviction}</span>
          </li>`).join('') || '<li class="dim empty-li">nothing yet</li>';
        $('recent').querySelectorAll('li[data-id]').forEach(li =>
          li.onclick = () => openThesis(li.dataset.id));
      } catch {}
    }

    async function openThesis(id) {
      render(await (await fetch(API + '/api/theses/' + id)).json());
    }

    function meter(label, pct) {
      return `<div class="meter"><span class="ml">${label}</span>
        <span class="track"><span class="fill" style="width:${pct}%"></span></span>
        <span class="mv">${pct}</span></div>`;
    }

    function render(t) {
      $('empty').classList.add('hidden');
      const m = $('memo'); m.classList.remove('hidden');
      const v = t.verification || {};
      const gr = Math.round((v.grounding_rate || 0) * 100);
      const ev = (t.sentiment?.evidence || []).map(c =>
        `<li class="quote">${esc(c.quote)}</li>`).join('');
      const guid = (t.guidance || []).map(g =>
        `<li><span class="pill">${dirGlyph[g.direction] || ''} ${esc(g.direction)}</span>
          <span class="pill-label">${esc(g.metric)}</span> ${esc(g.detail)}</li>`).join('')
        || '<li class="dim">none</li>';
      const risks = (t.risks || []).map(r =>
        `<li><span class="pill sev-${esc(r.severity)}">${esc(r.severity)} · ${esc(r.status)}</span>
          ${esc(r.description)}</li>`).join('') || '<li class="dim">none</li>';
      const cats = (t.catalysts || []).map(c => `<span class="chip">${esc(c)}</span>`).join('');
      const flagged = (v.flagged || []).map(c =>
        `<li class="quote flag">✗ ${esc(c.quote)}</li>`).join('');

      m.innerHTML = `
        <div class="memo-head animate-in">
          <div class="tk">${esc(t.ticker)} <span class="dim">/ ${esc(t.quarter)}</span></div>
          <h1 class="hl">${esc(t.headline)}</h1>
          <div class="stance">${stanceGlyph[t.stance] || '—'} ${esc(t.stance)}</div>
        </div>

        <div class="meters animate-in animate-delay-1">
          ${meter('conviction', t.conviction || 0)}
          ${meter('grounding', gr)}
          <div class="verifline">verifier / <b>${v.supported_claims||0}/${v.total_claims||0}</b>
            claims grounded · <b>${(v.flagged||[]).length}</b> flagged
            <span class="modechip">${esc(t.mode)} · ${esc(t.model_name)}</span>
          </div>
        </div>

        <div class="block animate-in animate-delay-2">
          <h2 class="section-label">management sentiment</h2>
          <div class="chips">
            <span class="chip">tone / ${esc(t.sentiment?.tone)}</span>
            <span class="chip">confidence / ${t.sentiment?.confidence_score}</span>
            <span class="chip">hedging / ${t.sentiment?.hedging_score}</span>
          </div>
          <p class="delta">${esc(t.sentiment?.qa_delta)}</p>
          <ul class="quotes">${ev}</ul>
        </div>

        <div class="block animate-in animate-delay-3">
          <h2 class="section-label">forward guidance</h2>
          <ul class="items">${guid}</ul>
        </div>

        <div class="block animate-in animate-delay-4">
          <h2 class="section-label">key risks</h2>
          <ul class="items">${risks}</ul>
        </div>

        <div class="block animate-in animate-delay-5">
          <h2 class="section-label">read</h2>
          <p><span class="k">catalysts</span> ${cats || '<span class="dim">—</span>'}</p>
          <p><span class="k">management credibility</span> ${esc(t.mgmt_credibility)}</p>
        </div>

        ${flagged ? `<div class="block flagged animate-in animate-delay-6">
          <h2 class="section-label">verifier flagged — removed, not grounded</h2>
          <ul class="quotes">${flagged}</ul></div>` : ''}
      `;
      m.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    async function analyze() {
      const btn = $('analyze');
      const transcript = $('transcript').value.trim();
      if (transcript.length < 50) { alert('paste a transcript first.'); return; }
      btn.disabled = true; btn.textContent = 'analyzing…';
      try {
        const res = await fetch(API + '/api/analyze', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ transcript, ticker: $('ticker').value || 'N/A', quarter: $('quarter').value || 'N/A' }),
        });
        if (!res.ok) throw new Error(await res.text());
        render(await res.json());
        loadRecent();
      } catch (e) {
        alert('analyze failed: ' + e.message);
      } finally {
        btn.disabled = false; btn.textContent = 'analyze →';
      }
    }

    $('loadSample').onclick = async () => {
      $('transcript').value = (await (await fetch(API + '/api/sample')).json()).transcript;
    };
    $('analyze').onclick = analyze;
    health(); loadRecent();
  </script>

  <style is:global>
    :root {
      --color-bg:#0a0a0a;
      --text-primary:rgba(255,255,255,.92); --text-body:rgba(255,255,255,.5);
      --text-secondary:rgba(255,255,255,.35); --text-muted:rgba(255,255,255,.25);
      --text-subtle:rgba(255,255,255,.15); --text-slash:rgba(255,255,255,.1);
      --border-default:rgba(255,255,255,.06); --border-hover:rgba(255,255,255,.15);
      --border-subtle:rgba(255,255,255,.04);
      --link-default:rgba(255,255,255,.4); --link-hover:rgba(255,255,255,.7);
      --font-mono:"JetBrains Mono",monospace; --font-display:"Sora",sans-serif;
      --space-md:1rem; --space-lg:1.5rem; --space-xl:2rem; --space-2xl:3rem;
      --max-width:720px; --page-gutter:3rem; --ease:cubic-bezier(.16,1,.3,1);
    }
    @media (max-width:768px){ :root{ --page-gutter:1.5rem; } }
    *,*::before,*::after{ box-sizing:border-box; margin:0; padding:0; }
    html{ font-size:16px; scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
    body{ font-family:var(--font-mono); font-weight:400; line-height:1.6;
      color:var(--text-body); background:var(--color-bg); min-height:100vh;
      -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }

    /* film grain — same as hadimoumeni.com */
    @keyframes grain{0%,100%{transform:translate(0)}10%{transform:translate(-5%,-10%)}
      20%{transform:translate(-15%,5%)}30%{transform:translate(7%,-25%)}
      40%{transform:translate(-5%,25%)}50%{transform:translate(-15%,10%)}
      60%{transform:translate(15%,0)}70%{transform:translateY(15%)}
      80%{transform:translate(3%,35%)}90%{transform:translate(-10%,10%)}}
    .grain{ position:fixed; top:-50%; left:-50%; width:200%; height:200%; z-index:9999;
      pointer-events:none; opacity:.025; animation:grain 8s steps(10) infinite;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }

    @keyframes fadeInUp{0%{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
    .animate-in{ animation:fadeInUp .6s var(--ease) forwards; opacity:0; }
    .animate-delay-1{animation-delay:.1s} .animate-delay-2{animation-delay:.2s}
    .animate-delay-3{animation-delay:.3s} .animate-delay-4{animation-delay:.4s}
    .animate-delay-5{animation-delay:.5s} .animate-delay-6{animation-delay:.6s}

    .wrap{ min-height:100vh; display:flex; flex-direction:column;
      padding:clamp(2rem,6vh,4rem) 0 2rem; }
    .container,.masthead,.bottom-bar{ width:100%; max-width:var(--max-width);
      margin:0 auto; padding-left:var(--page-gutter); padding-right:var(--page-gutter); }

    /* masthead */
    .masthead{ margin-bottom:var(--space-2xl); }
    .brand{ display:flex; align-items:baseline; gap:1rem; flex-wrap:wrap; }
    .site-name{ font-family:var(--font-display); font-weight:600; font-size:1rem;
      letter-spacing:.14em; color:var(--text-primary); text-transform:uppercase; }
    .currently{ font-size:.7rem; letter-spacing:.03em; color:var(--text-body);
      text-transform:lowercase; }
    .currently .label{ color:var(--text-muted); }
    .tagline{ margin-top:.7rem; font-size:.72rem; letter-spacing:.04em;
      color:var(--text-secondary); text-transform:lowercase; }

    /* input panel */
    .panel{ border-top:1px solid var(--border-default); padding-top:var(--space-lg);
      margin-bottom:var(--space-2xl); }
    .field-row{ display:flex; gap:1rem; margin-bottom:.9rem; }
    label{ flex:1; display:flex; flex-direction:column; gap:.4rem; font-size:.62rem;
      letter-spacing:.14em; text-transform:uppercase; color:var(--text-muted); }
    input,textarea{ font-family:var(--font-mono); color:var(--text-primary);
      background:transparent; border:1px solid var(--border-default);
      padding:.6rem .7rem; font-size:.82rem; width:100%; transition:border-color .3s ease; }
    input:focus,textarea:focus{ outline:none; border-color:var(--border-hover); }
    textarea{ height:clamp(180px,32vh,300px); resize:vertical; line-height:1.6;
      font-size:.78rem; color:var(--text-body); }
    input::placeholder,textarea::placeholder{ color:var(--text-subtle); }
    .actions{ display:flex; justify-content:flex-end; gap:.6rem; margin-top:.9rem; }
    .btn{ font-family:var(--font-mono); font-size:.72rem; letter-spacing:.08em;
      text-transform:uppercase; color:var(--text-primary); background:transparent;
      border:1px solid var(--border-hover); padding:.55rem 1.1rem; cursor:pointer;
      transition:color .3s ease,border-color .3s ease,background .3s ease; }
    .btn:hover{ background:#ffffff0d; border-color:var(--text-secondary); }
    .btn.ghost{ border-color:var(--border-default); color:var(--text-body); }
    .btn.ghost:hover{ color:var(--text-primary); }
    .btn:disabled{ opacity:.4; cursor:default; }

    .empty{ color:var(--text-secondary); font-size:.8rem; font-weight:300;
      line-height:1.7; margin-bottom:var(--space-2xl); max-width:52ch; }
    .dim{ color:var(--text-muted); } .hidden{ display:none; }

    /* memo */
    .memo-head{ margin-bottom:var(--space-xl); }
    .tk{ font-size:.72rem; letter-spacing:.1em; text-transform:uppercase;
      color:var(--text-secondary); }
    .hl{ font-family:var(--font-display); font-weight:500;
      font-size:clamp(1.4rem,3.6vw,2.2rem); line-height:1.2; color:var(--text-primary);
      margin:.5rem 0 .8rem; }
    .stance{ display:inline-block; font-size:.72rem; letter-spacing:.16em;
      text-transform:uppercase; color:var(--text-primary);
      border:1px solid var(--border-hover); padding:.35rem .7rem; }

    .meters{ padding:var(--space-lg) 0; border-top:1px solid var(--border-default);
      border-bottom:1px solid var(--border-default); margin-bottom:var(--space-xl); }
    .meter{ display:flex; align-items:center; gap:1rem; margin:.4rem 0; }
    .meter .ml{ width:6.5rem; font-size:.62rem; letter-spacing:.12em;
      text-transform:uppercase; color:var(--text-muted); }
    .meter .track{ flex:1; height:2px; background:var(--border-default); overflow:hidden; }
    .meter .fill{ display:block; height:100%; background:rgba(255,255,255,.85); }
    .meter .mv{ width:2rem; text-align:right; font-size:.72rem; color:var(--text-secondary); }
    .verifline{ font-size:.68rem; letter-spacing:.02em; color:var(--text-secondary);
      margin-top:.9rem; }
    .verifline b{ color:var(--text-primary); font-weight:500; }
    .modechip{ float:right; font-size:.6rem; letter-spacing:.05em; color:var(--text-muted);
      border:1px solid var(--border-default); padding:.15rem .5rem; }

    .block{ padding:var(--space-lg) 0; border-bottom:1px solid var(--border-default); }
    .section-label{ font-family:var(--font-mono); font-size:.62rem; font-weight:500;
      letter-spacing:.18em; text-transform:uppercase; color:var(--text-secondary);
      margin-bottom:var(--space-md); }
    .chips{ display:flex; gap:.5rem; flex-wrap:wrap; }
    .chip{ font-size:.66rem; letter-spacing:.04em; color:var(--text-body);
      border:1px solid var(--border-default); padding:.3rem .7rem; text-transform:lowercase; }
    .delta{ color:var(--text-secondary); font-size:.8rem; font-weight:300;
      line-height:1.7; margin:.9rem 0 0; }

    ul.quotes,ul.items{ list-style:none; margin:.6rem 0 0; }
    ul.items li{ padding:.5rem 0; font-size:.8rem; font-weight:300; line-height:1.6;
      color:var(--text-body); display:flex; gap:.7rem; align-items:baseline; flex-wrap:wrap; }
    .pill{ font-size:.6rem; letter-spacing:.1em; text-transform:uppercase; font-weight:500;
      color:var(--text-primary); border:1px solid var(--border-hover); padding:.2rem .5rem;
      white-space:nowrap; }
    .pill.sev-high{ color:var(--text-primary); border-color:var(--text-secondary); }
    .pill.sev-medium{ color:var(--text-secondary); }
    .pill.sev-low{ color:var(--text-muted); border-color:var(--border-default); }
    .pill-label{ color:var(--text-primary); text-transform:uppercase; font-size:.68rem;
      letter-spacing:.04em; }
    .quote{ padding:.55rem .9rem; margin:.5rem 0; font-size:.76rem; font-weight:300;
      line-height:1.6; color:var(--text-secondary); border-left:1px solid var(--border-hover);
      background:#ffffff05; }
    .quote.flag{ color:var(--text-muted); border-left-color:var(--text-subtle);
      text-decoration:line-through; text-decoration-color:var(--text-subtle); }
    .k{ display:inline-block; min-width:9.5rem; font-size:.6rem; letter-spacing:.12em;
      text-transform:uppercase; color:var(--text-muted); }
    .block p{ font-size:.8rem; font-weight:300; line-height:1.7; color:var(--text-body);
      margin-bottom:.5rem; }

    /* recent */
    .recent-wrap{ margin-top:var(--space-2xl); }
    .recent{ list-style:none; }
    .recent li{ display:flex; align-items:center; gap:.9rem; padding:.55rem 0;
      font-size:.76rem; border-bottom:1px solid var(--border-subtle); cursor:pointer;
      color:var(--text-body); transition:color .2s ease; }
    .recent li[data-id]:hover{ color:var(--text-primary); }
    .recent .r-glyph{ color:var(--text-muted); width:1rem; }
    .recent .r-tk{ flex:1; text-transform:uppercase; letter-spacing:.04em; }
    .recent .r-conv{ color:var(--text-muted); }
    .recent .empty-li{ cursor:default; border:none; }

    /* footer */
    .bottom-bar{ margin-top:var(--space-2xl); display:flex; align-items:center; gap:.6rem;
      font-size:.62rem; letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); }
    .bottom-bar .dot{ color:var(--text-subtle); }
    .social-links a{ color:var(--link-default); text-decoration:none;
      border-bottom:1px solid var(--border-default); transition:color .3s ease,border-color .3s ease; }
    .social-links a:hover{ color:var(--link-hover); border-bottom-color:var(--border-hover); }

    @media (max-width:768px){
      .field-row{ flex-direction:column; gap:.6rem; }
      .modechip{ float:none; display:inline-block; margin-top:.4rem; }
    }
  </style>
</body>
</html>
