---
// The Wire — single-page UI. Static build; talks to the FastAPI service.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>The Wire — earnings-call intelligence</title>
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <span class="mark">◍ THE&nbsp;WIRE</span>
      <span class="tag">earnings calls → verified investment theses</span>
    </div>
    <div id="modelBadge" class="badge muted">checking model…</div>
  </header>

  <main class="grid">
    <!-- Input column -->
    <section class="col input">
      <div class="row">
        <label>Ticker <input id="ticker" value="NWL" /></label>
        <label>Quarter <input id="quarter" value="Q3 2026" /></label>
      </div>
      <textarea id="transcript" placeholder="Paste an earnings-call transcript…"></textarea>
      <div class="row btns">
        <button id="loadSample" class="ghost">Load sample</button>
        <button id="analyze" class="primary">Analyze →</button>
      </div>

      <h3 class="recent-h">Recent</h3>
      <ul id="recent" class="recent"></ul>
    </section>

    <!-- Output column -->
    <section class="col output">
      <div id="empty" class="empty">
        <p>Paste a transcript and hit <b>Analyze</b>.</p>
        <p class="dim">Three specialist agents (sentiment · risk · guidance) run in
        parallel; a verifier checks every quote against the transcript before the
        thesis ships.</p>
      </div>
      <div id="memo" class="memo hidden"></div>
    </section>
  </main>

  <script>
    const API = location.port === '4321' ? 'http://localhost:2424' : '';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s ?? '').toString()
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');

    const stanceClass = { bullish: 'bull', bearish: 'bear', neutral: 'neu' };
    const dirClass = { raised: 'bull', lowered: 'bear', withdrawn: 'bear',
                       maintained: 'neu', introduced: 'neu', unclear: 'muted' };
    const sevClass = { high: 'bear', medium: 'neu', low: 'muted' };

    async function health() {
      try {
        const h = await (await fetch(API + '/api/health')).json();
        const b = $('modelBadge');
        if (h.model_available) { b.textContent = '● ' + h.model; b.className = 'badge live'; }
        else { b.textContent = '● heuristic mode (no model)'; b.className = 'badge warn'; }
      } catch { $('modelBadge').textContent = '● API offline'; }
    }

    async function loadRecent() {
      try {
        const rows = await (await fetch(API + '/api/theses')).json();
        $('recent').innerHTML = rows.map(r => `
          <li data-id="${r.id}">
            <span class="dot ${stanceClass[r.stance] || 'muted'}"></span>
            <span class="t">${esc(r.ticker)} · ${esc(r.quarter)}</span>
            <span class="c">${r.conviction}</span>
          </li>`).join('') || '<li class="dim">nothing yet</li>';
        $('recent').querySelectorAll('li[data-id]').forEach(li =>
          li.onclick = () => openThesis(li.dataset.id));
      } catch {}
    }

    async function openThesis(id) {
      const t = await (await fetch(API + '/api/theses/' + id)).json();
      render(t);
    }

    function meter(label, pct, cls) {
      return `<div class="meter"><span class="ml">${label}</span>
        <span class="track"><span class="fill ${cls}" style="width:${pct}%"></span></span>
        <span class="mv">${pct}</span></div>`;
    }

    function render(t) {
      $('empty').classList.add('hidden');
      const m = $('memo'); m.classList.remove('hidden');
      const v = t.verification || {};
      const gr = Math.round((v.grounding_rate || 0) * 100);
      const ev = (t.sentiment?.evidence || []).map(c =>
        `<li class="quote ok">“${esc(c.quote)}”</li>`).join('');
      const guid = (t.guidance || []).map(g =>
        `<li><span class="pill ${dirClass[g.direction] || 'muted'}">${esc(g.direction)}</span>
          <b>${esc(g.metric)}</b> — ${esc(g.detail)}</li>`).join('') || '<li class="dim">none</li>';
      const risks = (t.risks || []).map(r =>
        `<li><span class="pill ${sevClass[r.severity] || 'muted'}">${esc(r.severity)}/${esc(r.status)}</span>
          ${esc(r.description)}</li>`).join('') || '<li class="dim">none</li>';
      const cats = (t.catalysts || []).map(c => `<span class="chip">${esc(c)}</span>`).join('');
      const flagged = (v.flagged || []).map(c =>
        `<li class="quote bad">✗ (${Math.round(c.score||0)}) “${esc(c.quote)}”</li>`).join('');

      m.innerHTML = `
        <div class="memo-head">
          <div class="mh-left">
            <div class="tk">${esc(t.ticker)} <span class="dim">· ${esc(t.quarter)}</span></div>
            <div class="hl">${esc(t.headline)}</div>
          </div>
          <div class="stance ${stanceClass[t.stance] || 'neu'}">${esc(t.stance)}</div>
        </div>
        <div class="meters">
          ${meter('conviction', t.conviction || 0, stanceClass[t.stance] || 'neu')}
          ${meter('grounding', gr, gr >= 80 ? 'bull' : gr >= 50 ? 'neu' : 'bear')}
          <div class="verifline">verifier: <b>${v.supported_claims||0}/${v.total_claims||0}</b>
            claims grounded · <b>${(v.flagged||[]).length}</b> flagged
            <span class="modechip ${t.mode === 'ollama' ? 'live' : 'warn'}">${esc(t.mode)} · ${esc(t.model_name)}</span>
          </div>
        </div>

        <div class="block">
          <h4>Management sentiment</h4>
          <div class="chips">
            <span class="chip">tone: ${esc(t.sentiment?.tone)}</span>
            <span class="chip">confidence: ${t.sentiment?.confidence_score}</span>
            <span class="chip">hedging: ${t.sentiment?.hedging_score}</span>
          </div>
          <p class="delta">${esc(t.sentiment?.qa_delta)}</p>
          <ul class="quotes">${ev}</ul>
        </div>

        <div class="block"><h4>Forward guidance</h4><ul class="items">${guid}</ul></div>
        <div class="block"><h4>Key risks</h4><ul class="items">${risks}</ul></div>

        <div class="block">
          <h4>Read</h4>
          <p><b>Catalysts:</b> ${cats || '<span class="dim">—</span>'}</p>
          <p><b>Management credibility:</b> ${esc(t.mgmt_credibility)}</p>
        </div>

        ${flagged ? `<div class="block flagged"><h4>⚠ Verifier flagged (removed — not grounded)</h4>
          <ul class="quotes">${flagged}</ul></div>` : ''}
      `;
      m.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    async function analyze() {
      const btn = $('analyze');
      const transcript = $('transcript').value.trim();
      if (transcript.length < 50) { alert('Paste a transcript first.'); return; }
      btn.disabled = true; btn.textContent = 'Analyzing…';
      try {
        const res = await fetch(API + '/api/analyze', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            transcript, ticker: $('ticker').value || 'N/A',
            quarter: $('quarter').value || 'N/A',
          }),
        });
        if (!res.ok) throw new Error(await res.text());
        render(await res.json());
        loadRecent();
      } catch (e) {
        alert('Analyze failed: ' + e.message);
      } finally {
        btn.disabled = false; btn.textContent = 'Analyze →';
      }
    }

    $('loadSample').onclick = async () => {
      const d = await (await fetch(API + '/api/sample')).json();
      $('transcript').value = d.transcript;
    };
    $('analyze').onclick = analyze;

    health(); loadRecent();
  </script>

  <style is:global>
    :root {
      --bg:#0b0e13; --panel:#12161e; --panel2:#171c26; --line:#232a36;
      --ink:#e7ecf3; --dim:#8b96a6; --muted:#6b7688;
      --bull:#37d399; --bear:#f2555a; --neu:#f4b740; --accent:#5b9dff;
    }
    * { box-sizing: border-box; }
    body { margin:0; background:var(--bg); color:var(--ink);
      font:15px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; }
    .topbar { display:flex; justify-content:space-between; align-items:center;
      padding:14px 22px; border-bottom:1px solid var(--line); background:var(--panel); }
    .brand { display:flex; align-items:baseline; gap:14px; }
    .mark { font-weight:800; letter-spacing:.5px; font-size:19px; }
    .tag { color:var(--muted); font-size:13px; }
    .badge { font-size:12px; padding:5px 10px; border-radius:20px; border:1px solid var(--line);
      font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
    .badge.live { color:var(--bull); border-color:#1e4d3d; background:#0e1a15; }
    .badge.warn { color:var(--neu); border-color:#4d3f1e; background:#1a160e; }
    .badge.muted { color:var(--muted); }

    .grid { display:grid; grid-template-columns:400px 1fr; gap:18px; padding:18px 22px;
      max-width:1280px; margin:0 auto; align-items:start; }
    @media (max-width:900px){ .grid { grid-template-columns:1fr; } }
    .col { background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:16px; }

    .row { display:flex; gap:10px; }
    label { display:flex; flex-direction:column; gap:4px; font-size:12px; color:var(--muted); flex:1; }
    input, textarea { background:var(--panel2); border:1px solid var(--line); color:var(--ink);
      border-radius:8px; padding:9px 11px; font:inherit; width:100%; }
    textarea { height:340px; margin:12px 0; resize:vertical; font-size:13px;
      font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
    .btns { justify-content:flex-end; }
    button { border-radius:8px; padding:10px 16px; font:inherit; font-weight:600; cursor:pointer;
      border:1px solid var(--line); }
    button.ghost { background:transparent; color:var(--ink); }
    button.primary { background:var(--accent); border-color:var(--accent); color:#06101f; }
    button:disabled { opacity:.55; cursor:default; }

    .recent-h { font-size:12px; text-transform:uppercase; letter-spacing:.6px; color:var(--muted);
      margin:20px 0 8px; }
    .recent { list-style:none; margin:0; padding:0; }
    .recent li { display:flex; align-items:center; gap:9px; padding:8px 6px; border-radius:7px;
      cursor:pointer; font-size:13px; }
    .recent li:hover { background:var(--panel2); }
    .recent .t { flex:1; } .recent .c { color:var(--muted); font-family:ui-monospace,monospace; }
    .dot { width:8px; height:8px; border-radius:50%; background:var(--muted); }
    .dot.bull{background:var(--bull)} .dot.bear{background:var(--bear)} .dot.neu{background:var(--neu)}

    .empty { color:var(--muted); padding:40px 20px; }
    .empty .dim { font-size:13px; }
    .dim { color:var(--muted); } .hidden { display:none; }

    .memo-head { display:flex; justify-content:space-between; align-items:flex-start; gap:16px;
      border-bottom:1px solid var(--line); padding-bottom:14px; }
    .tk { font-family:ui-monospace,monospace; font-size:15px; color:var(--accent); }
    .hl { font-size:20px; font-weight:700; margin-top:4px; }
    .stance { text-transform:uppercase; font-weight:800; font-size:13px; letter-spacing:.5px;
      padding:8px 14px; border-radius:8px; align-self:center; }
    .stance.bull{background:#0e1a15;color:var(--bull);border:1px solid #1e4d3d}
    .stance.bear{background:#1c0f10;color:var(--bear);border:1px solid #4d1e20}
    .stance.neu{background:#1a160e;color:var(--neu);border:1px solid #4d3f1e}

    .meters { padding:14px 0; border-bottom:1px solid var(--line); }
    .meter { display:flex; align-items:center; gap:10px; margin:6px 0; }
    .meter .ml { width:90px; font-size:12px; color:var(--muted); }
    .meter .track { flex:1; height:8px; background:var(--panel2); border-radius:5px; overflow:hidden; }
    .meter .fill { display:block; height:100%; }
    .fill.bull{background:var(--bull)} .fill.bear{background:var(--bear)} .fill.neu{background:var(--neu)}
    .meter .mv { width:34px; text-align:right; font-family:ui-monospace,monospace; font-size:12px; }
    .verifline { font-size:12.5px; color:var(--dim); margin-top:8px; }
    .verifline b { color:var(--ink); }
    .modechip { float:right; font-family:ui-monospace,monospace; font-size:11px; padding:2px 8px;
      border-radius:12px; border:1px solid var(--line); }
    .modechip.live{color:var(--bull)} .modechip.warn{color:var(--neu)}

    .block { padding:14px 0; border-bottom:1px solid var(--line); }
    .block h4 { margin:0 0 10px; font-size:13px; text-transform:uppercase; letter-spacing:.5px; color:var(--muted); }
    .chips { display:flex; gap:8px; flex-wrap:wrap; }
    .chip { background:var(--panel2); border:1px solid var(--line); border-radius:20px;
      padding:4px 11px; font-size:12px; }
    .delta { color:var(--dim); font-size:13.5px; margin:10px 0; }
    ul.quotes, ul.items { list-style:none; margin:8px 0 0; padding:0; }
    ul.items li { padding:7px 0; font-size:13.5px; display:flex; gap:9px; align-items:baseline; }
    .pill { font-size:11px; text-transform:uppercase; padding:2px 8px; border-radius:5px;
      font-weight:700; white-space:nowrap; }
    .pill.bull{background:#0e1a15;color:var(--bull)} .pill.bear{background:#1c0f10;color:var(--bear)}
    .pill.neu{background:#1a160e;color:var(--neu)} .pill.muted{background:var(--panel2);color:var(--muted)}
    .quote { padding:7px 11px; margin:6px 0; border-radius:7px; font-size:13px; border-left:2px solid; }
    .quote.ok { background:#0d1512; border-color:var(--bull); color:#c9e7db; }
    .quote.bad { background:#160f10; border-color:var(--bear); color:#e7c9cb; }
    .flagged h4 { color:var(--bear); }
  </style>
</body>
</html>
